# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────
dist/
dist-ssr/
build/
*.tsbuildinfo

# ── Environment / secrets — NEVER commit real keys ───────────
# Ignores .env, .env.local, .env.seed, .env.*.local, etc.
.env
.env.*
*.local
# ...but DO keep the example templates (placeholders only)
!.env.example
!.env.*.example

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Deploy / hosting ─────────────────────────────────────────
.vercel
.netlify

# ── Supabase CLI (local-only artifacts) ──────────────────────
supabase/.temp/
supabase/.branches/

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
