# Admin console env — copy this file to .env.local and fill in your values.
# Use the SAME Supabase project as the main app (Dashboard → Project Settings → API).
# The publishable (anon) key is browser-safe; admins only ever see platform-wide
# data because they sign in and RLS checks is_admin() (profiles.role = 'admin').
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
