# Used ONLY by the one-time seed script (npm run seed). Copy to .env.seed and fill in.
# The service_role key is powerful (bypasses RLS) — keep .env.seed private, never commit it,
# and never paste it in chat. It is NOT VITE_-prefixed, so it never reaches the browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-secret-key
